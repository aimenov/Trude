generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(uuid())
  nickname         String
  avatar           String              @default("a0")
  deviceId         String?             @unique
  createdAt        DateTime            @default(now())
  premium          Boolean             @default(false)
  selectedCardBack String              @default("cb_classic")
  selectedFelt     String              @default("felt_classic")
  identities       Identity[]
  stats            PlayerStats?
  achievements     UserAchievement[]
  wallet           Wallet?
  ledger           CoinLedger[]
  rating           Rating?
  seasonScores     SeasonScore[]
  dailyState       DailyState?
  questProgress    QuestProgress[]
  cosmetics        CosmeticOwnership[]
  iapReceipts      IapReceipt[]
}

model Identity {
  id             String @id @default(uuid())
  userId         String
  provider       String // "google" | "apple"
  providerUserId String
  user           User   @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
}

model PlayerStats {
  userId         String @id
  gamesPlayed    Int    @default(0)
  gamesWon       Int    @default(0)
  gamesLost      Int    @default(0)
  winStreak      Int    @default(0)
  bestWinStreak  Int    @default(0)
  liesSurvived   Int    @default(0)
  liesCaught     Int    @default(0)
  checksWon      Int    @default(0)
  checksLost     Int    @default(0)
  cardsPickedUp  Int    @default(0)
  quadsDiscarded Int    @default(0)
  jokerPassed    Int    @default(0)
  jokerSmuggles  Int    @default(0)
  truthfulThrows Int    @default(0)
  lyingThrows    Int    @default(0)
  user           User   @relation(fields: [userId], references: [id])
}

model UserAchievement {
  userId     String
  key        String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, key])
}

model GameResult {
  id           String   @id @default(uuid())
  roomId       String
  deckSize     Int
  status       String // FINISHED | ABANDONED
  loserUserId  String?
  participants Json // [{userId, placement}]
  endedAt      DateTime @default(now())
  isPrivate    Boolean  @default(false)
  actionCount  Int      @default(0)
  rated        Boolean  @default(false)
}

model Wallet {
  userId String @id
  coins  Int    @default(0)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoinLedger {
  id             String   @id @default(uuid())
  userId         String
  delta          Int
  reason         String // GAME_AWARD | DAILY_BONUS | QUEST | QUEST_BONUS | SHOP_PURCHASE | AD_REWARD | AD_DOUBLE | IAP
  idempotencyKey String   @unique
  meta           Json?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, reason, createdAt])
}

model Rating {
  userId     String @id
  rating     Int    @default(1000)
  peakRating Int    @default(1000)
  gamesRated Int    @default(0)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([rating])
}

model SeasonScore {
  seasonKey  String
  userId     String
  points     Int    @default(0)
  gamesRated Int    @default(0)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([seasonKey, userId])
  @@index([seasonKey, points])
}

model DailyState {
  userId       String  @id
  lastClaimDay String?
  streak       Int     @default(0)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestProgress {
  userId      String
  day         String
  questKey    String
  progress    Int       @default(0)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day, questKey])
}

model CosmeticOwnership {
  userId     String
  itemKey    String
  acquiredAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, itemKey])
}

model IapReceipt {
  id         String   @id @default(uuid())
  userId     String
  platform   String // google | apple
  productId  String
  orderId    String   @unique
  status     String // GRANTED
  rawPayload Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
